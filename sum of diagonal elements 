        }
        printf("\n");
    }
      printf("\n The sum of diagonal elements are :");
      sd=0;
    for(i=0;i<3;i++)
   {
        for(j=0;j<3;j++)
        {
            if(i==j)
            {
            printf("\n %d",a[i][j]);
         sd=sd+a[i][j];
            }
        }
    }
